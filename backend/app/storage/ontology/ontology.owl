<?xml version="1.0"?>
<rdf:RDF xmlns="https://github.com/prashant-sgh/ccmo#" xml:base="https://github.com/prashant-sgh/ccmo"
xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
xmlns:owl="http://www.w3.org/2002/07/owl#"
xmlns:xsd="http://www.w3.org/2001/XMLSchema#">
<owl:Ontology rdf:about="https://github.com/prashant-sgh/ccmo"><rdfs:label>CCMO</rdfs:label><owl:versionInfo>1.0</owl:versionInfo></owl:Ontology>
<owl:Class rdf:about="#Patient"/>
<owl:Class rdf:about="#ClinicalVisit"/>
<owl:Class rdf:about="#HealthcareProvider"/>
<owl:Class rdf:about="#Hospital"/>
<owl:Class rdf:about="#Department"/>
<owl:Class rdf:about="#Condition"/>
<owl:Class rdf:about="#Medication"/>
<owl:Class rdf:about="#LaboratoryTest"/>
<owl:Class rdf:about="#ClinicalObservation"/>
<owl:Class rdf:about="#VitalSign"/>
<owl:Class rdf:about="#LifestyleIntervention"/>
<owl:Class rdf:about="#Education"/>
<owl:Class rdf:about="#Procedure"/>
<owl:Class rdf:about="#Assessment"/>
<owl:Class rdf:about="#TreatmentPlan"/>
<owl:Class rdf:about="#FollowUp"/>
<owl:Class rdf:about="#MemoryEvent"/>
<owl:Class rdf:about="#ClinicalTimeline"/>
<owl:ObjectProperty rdf:about="#hasVisit"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#ClinicalVisit"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#hasCondition"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#Condition"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#takesMedication"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#Medication"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#treatedWith"><rdfs:domain rdf:resource="#Condition"/><rdfs:range rdf:resource="#Medication"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#monitoredBy"><rdfs:domain rdf:resource="#Condition"/><rdfs:range rdf:resource="#LaboratoryTest"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#performedBy"><rdfs:domain rdf:resource="#ClinicalVisit"/><rdfs:range rdf:resource="#HealthcareProvider"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#occurredAt"><rdfs:domain rdf:resource="#ClinicalVisit"/><rdfs:range rdf:resource="#Hospital"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#hasObservation"><rdfs:domain rdf:resource="#ClinicalVisit"/><rdfs:range rdf:resource="#ClinicalObservation"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#hasVital"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#VitalSign"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#receivedEducation"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#Education"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#underwentProcedure"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#Procedure"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#targetsCondition"><rdfs:domain rdf:resource="#TreatmentPlan"/><rdfs:range rdf:resource="#Condition"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#prescribedDuring"><rdfs:domain rdf:resource="#Medication"/><rdfs:range rdf:resource="#ClinicalVisit"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#resultOf"><rdfs:domain rdf:resource="#ClinicalObservation"/><rdfs:range rdf:resource="#LaboratoryTest"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#belongsToDataset"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="#ClinicalTimeline"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#memberOfNodeSet"><rdfs:domain rdf:resource="#MemoryEvent"/><rdfs:range rdf:resource="#ClinicalTimeline"/></owl:ObjectProperty>
<owl:ObjectProperty rdf:about="#nextEvent"><rdfs:domain rdf:resource="#MemoryEvent"/><rdfs:range rdf:resource="#MemoryEvent"/></owl:ObjectProperty>
<owl:DatatypeProperty rdf:about="#name"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#mrn"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#age"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#sex"><rdfs:domain rdf:resource="#Patient"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#date"><rdfs:domain rdf:resource="#ClinicalVisit"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#visitType"><rdfs:domain rdf:resource="#ClinicalVisit"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#diagnosisDate"><rdfs:domain rdf:resource="#Condition"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#status"><rdfs:domain rdf:resource="#Condition"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#dose"><rdfs:domain rdf:resource="#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#frequency"><rdfs:domain rdf:resource="#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#route"><rdfs:domain rdf:resource="#Medication"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#value"><rdfs:domain rdf:resource="#ClinicalObservation"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#unit"><rdfs:domain rdf:resource="#ClinicalObservation"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#summary"><rdfs:domain rdf:resource="#Assessment"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
<owl:DatatypeProperty rdf:about="#severity"><rdfs:domain rdf:resource="#Assessment"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
</rdf:RDF>